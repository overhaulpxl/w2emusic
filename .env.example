# ==============================
# W2E Music Bot Configuration
# ==============================
# Isi token bot Discord Anda di sini.
# Jangan pernah upload file .env asli ke publik.

# Basic Bot 1
BASIC_TOKEN_1=your_first_discord_bot_token_here
BASIC_PREFIX_1=w!

# Basic Bot 2 (optional)
BASIC_TOKEN_2=your_second_discord_bot_token_here
BASIC_PREFIX_2=w2!

# Basic Bot 3 (optional)
BASIC_TOKEN_3=your_third_discord_bot_token_here
BASIC_PREFIX_3=w3!

# Basic Bot 4 (optional)
BASIC_TOKEN_4=your_fourth_discord_bot_token_here
BASIC_PREFIX_4=w4!

# Basic Bot 5 (optional)
BASIC_TOKEN_5=your_fifth_discord_bot_token_here
BASIC_PREFIX_5=w5!

# Optional: only if running bot.py directly instead of launcher.py
# DISCORD_TOKEN=your_discord_bot_token_here
# BOT_PREFIX=w!

# Optional: yt-dlp cookies for YouTube anti-bot/sign-in checks
# Export cookies from your own browser session and save them locally.
# Never commit this file.
# Local path (tanpa Docker):
# YTDLP_COOKIES_FILE=./cookies/youtube_cookies.txt
#
# Docker path (karena ter-mount ke /app):
# YTDLP_COOKIES_FILE=/app/cookies/youtube_cookies.txt